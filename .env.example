# Database — Neon Postgres on Vercel Marketplace
# Provisioned automatically when you install the Neon integration.
# Locally: vercel env pull .env.local
DATABASE_URL=

# Clerk — auth (Marketplace integration auto-provisions these)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/admin
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/admin

# AI providers — direct (chosen over AI Gateway per project decision)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Optional model overrides — defaults match @ai-sdk/anthropic types.
# ANTHROPIC_MODEL_FAST=claude-sonnet-4-6
# ANTHROPIC_MODEL_DEEP=claude-opus-4-7

# Email — Resend (for outreach send + form notifications)
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@stacksquare.ai
NOTIFY_EMAILS=arif@stacksquare.ai,kerem@stacksquare.ai

# Public site
NEXT_PUBLIC_SITE_URL=https://stacksquare.ai
